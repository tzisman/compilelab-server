## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# OLAP Engine temporary files
*.atpl
*.asln

# EAZfuscator.NET build temporary files
*.vshost.exe
*.vshost.exe.config
*.vshost.exe.manifest

# ClickOnce directory
publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
# Note: Comment the next line if you want to checkin your web deploy settings,
# but be aware that they can contain sensitive information
*.pubxml
*.publishproj

# Microsoft Azure Build Output
csx/
*.build.csdef

# Microsoft Azure Cloud Service projects
*.azurePubxml

# Azure Stream Analytics local run output
ASALocalRun/

# Backup & checkpoint files from Gulp
_Chutzpah*

# AI/Python build outputs
node_modules/
/bower_components/

# Rider
.idea/
*.sln.iml

# External libraries
*.dll
*.exe
*.pdb
*.nupkg
ען
# NuGet Packages
*.nuget.props
*.nuget.targets

# Visual Studio Code
.vscode/

# Local settings
appsettings.Development.json
appsettings.Local.json

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
